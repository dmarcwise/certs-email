{
	"name": "certs-email",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate-migration": "prisma migrate dev --create-only",
		"migrate": "prisma migrate deploy",
		"check-updates": "npx npm-check-updates -i --format group,repo --cooldown 1d",
		"check-updates-semver": "npx npm-check-updates -i --format group,repo --cooldown 1d --target semver"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^24.13.2",
		"@types/pg": "^8.20.0",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^7.3.6"
	},
	"dependencies": {
		"@fontsource/firago": "^5.2.5",
		"@lucide/svelte": "^1.23.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"handlebars": "^4.7.9",
		"ipaddr.js": "^2.4.0",
		"juice": "^12.1.1",
		"lettermint": "^2.0.0",
		"mode-watcher": "^1.1.0",
		"pg": "^8.22.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.8.0",
